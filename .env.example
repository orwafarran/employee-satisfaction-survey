# ---------------------------------------------------------------------------
# Employee Satisfaction Survey — environment configuration
#
# Nothing here is required for a LOCAL run (PC or company server): the app uses
# a built-in SQLite file and a default admin login (admin / admin) that you
# change from the dashboard's Settings on first sign-in.
#
# The variables below matter for the ONLINE / Azure deployment. Set them as
# "Application settings" in Azure App Service (not in a committed file).
# ---------------------------------------------------------------------------

# --- ONLINE (Azure) ---------------------------------------------------------

# Turns on production mode (secure HTTPS-only session cookie). Set on Azure.
NODE_ENV=production

# Azure Database for PostgreSQL connection string. When set, the app uses
# Postgres instead of the local SQLite file. Example:
#   postgresql://USER:PASSWORD@HOST.postgres.database.azure.com:5432/survey?sslmode=require
DATABASE_URL=

# TLS to the database:
#   unset / "verify" -> TLS + verify the server certificate  (use this on Azure)
#   "no-verify"      -> TLS but skip cert verification  (only if you hit a
#                       certificate error connecting to the DB)
#   "disable"        -> no TLS  (plain local Postgres while testing)
# DATABASE_SSL=disable

# Optional: the public URL, used for the dashboard's "Copy survey link" button.
# If unset, the app uses whatever address the admin opened the dashboard on.
#   PUBLIC_URL=https://yourcompany-survey.azurewebsites.net

# --- Optional everywhere ----------------------------------------------------

# Port to listen on. Azure App Service sets this automatically; default 3000.
# PORT=3000

# Total headcount N, to show "X of N responses". Leave blank to hide.
SURVEY_HEADCOUNT=

# Session cookie secret. Optional — the app generates a strong one on first run
# and stores it in the database. Set explicitly only if you want to control it.
# SESSION_SECRET=

# --- Advanced: pre-seed the admin login (skips the admin/admin default) -----
# Normally you just sign in with admin/admin and set your real login in Settings.
# To bake credentials in instead, set BOTH of these:
#   ADMIN_USERNAME=you@company.com
#   ADMIN_PASSWORD_HASH=    # output of: node scripts/hash-password.js "your password"

# Auth provider: "local" (email + password). "entra" (Microsoft SSO) is a future
# add-on that needs tenant configuration.
AUTH_PROVIDER=local

# Local SQLite file location (local mode only). Defaults to ./data/survey.db
# DB_PATH=./data/survey.db
