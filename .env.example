# ---------------------------------------------------------------------------
# Employee Satisfaction Survey — environment configuration
# Copy this file to ".env" for local runs, or set these as real environment
# variables in the hosting platform at deploy time (Phase 6).
# Nothing here is required for local dev — sensible defaults are built in.
# ---------------------------------------------------------------------------

# Port the server listens on.
PORT=3000

# --- Admin login (pluggable "local" provider) ---------------------------------
# The admin username. Default for local dev: admin
ADMIN_USERNAME=admin

# The admin password. For local dev you may set a plain password here and the
# server will hash it on boot. For production set ADMIN_PASSWORD_HASH instead
# (generate with:  npm run -s start  is NOT how — use: node scripts/hash-password.js )
ADMIN_PASSWORD=change-me-please

# Pre-hashed admin password (scrypt). If set, this WINS over ADMIN_PASSWORD.
# Generate one with:  node scripts/hash-password.js "your strong password"
# ADMIN_PASSWORD_HASH=scrypt$...

# Secret used to sign the admin session cookie. Set a long random value in prod.
SESSION_SECRET=dev-only-insecure-secret-change-me

# --- Auth provider selection --------------------------------------------------
# "local"  = username + hashed password (default, works everywhere)
# "entra"  = Microsoft Entra ID SSO (Phase 6, requires tenant config — not wired by default)
AUTH_PROVIDER=local

# --- Survey settings ----------------------------------------------------------
# Optional total headcount N, to show "X of N responses". Leave blank to hide.
SURVEY_HEADCOUNT=

# Database file location (full app only). Defaults to ./data/survey.db
# DB_PATH=./data/survey.db
